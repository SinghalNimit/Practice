        \}\
    \}\
    increment()\{\
        this.setState(\{\
            count: this.state.count+1\
        \},()=>\{console.log('Callback Value : '+this.state.count)\})\
        console.log(this.state.count)\
    \}\
    incrementFive()\{\
        this.increment();\
        this.increment();\
        this.increment();\
        this.increment();\
        this.increment();\
        \
    \}\
    render() \{\
        return (\
            <div>\
            <div>\
                count - \{this.state.count\}\
            </div>\
